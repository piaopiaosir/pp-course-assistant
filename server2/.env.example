# 第二台服务器配置

# 主服务器地址（用于同步代码）
MAIN_SERVER=43.139.12.117
MAIN_PORT=3000

# 内部API密钥（必须与主服务器一致）
INTERNAL_API_KEY=internal-secret-key-2024

# 本地端口
PORT=3000

# 同步间隔（毫秒），默认1小时
SYNC_INTERVAL=3600000

# MySQL 数据库配置（与主服务器相同）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tiku

# 题库密钥（可选，如果主服务器有配置）
TIKU_API_KEY_1=
TIKU_API_KEY_2=
HIVENET_KEY=
YANXI_KEY=
